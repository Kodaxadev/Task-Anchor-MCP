# Auto-detect text files and normalise line endings to LF
* text=auto eol=lf

# Explicitly declare text files
*.py text eol=lf
*.md text eol=lf
*.toml text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.cfg text eol=lf
*.txt text eol=lf
*.mdc text eol=lf

# Binary files
*.png binary
*.jpg binary
*.ico binary
